# Frontend (client/.env)
VITE_MAPBOX_TOKEN=your_mapbox_token_here
# VITE_API_URL: leave empty for local dev (Vite proxy rewrites /api → localhost:3001).
# Set to the full API origin only for production deployments where the proxy is not used.
VITE_API_URL=

# Backend (server/.env)
PORT=3001
CORS_ORIGIN=http://localhost:5173
